{
  "name": "fantasy-game-next-react",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "homepage": "https://github.com/lucashdp/fantasy-game-test#readme",
  "bugs": {
    "url": "https://github.com/lucashdp/fantasy-game-test/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucashdp/fantasy-game-test.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "next.config.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cypress:web": "npx cypress open",
    "cypress:run": "cypress run",
    "cypress:run:report": "cypress run --reporter mochawesome && node scripts/combine-reports.js",
    "coverage:open": "start coverage/lcov-report/index.html",
    "cypress:report:open": "powershell -Command \"Get-ChildItem -Path cypress/reports/*.html | Sort-Object LastWriteTime -Descending | Select-Object -First 1 | ForEach-Object { Start-Process $_.FullName }\"",
    "cypress:report:combined": "start cypress/reports/relatorio_geral.html",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^18.3.1",
    "react-dom": "18.x",
    "swr": "^2.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.2",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "22.15.3",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@types/testing-library__react": "^10.0.1",
    "autoprefixer": "^10.0.0",
    "cypress": "^14.3.2",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-real-events": "^1.14.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "msw": "^2.7.5",
    "open": "^10.1.2",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^4.9.0"
  }
}
